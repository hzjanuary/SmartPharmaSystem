# SmartPharma AI Service environment variables

# Gemini API key for AI service internals
GEMINI_API_KEY=AIzaSyAdaJRozJIkag4afnvJIZeyEbYo2rQ8cyM

# Database connection (SQLAlchemy URL)
# Docker + XAMPP/MySQL on host machine:
# DATABASE_URL=mysql+pymysql://root@host.docker.internal:3306/pharmacymanagement
# Local run to local MySQL:
# DATABASE_URL=mysql+pymysql://root:your_password@127.0.0.1:3306/pharmacymanagement
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/pharmacymanagement
DATABASE_URL=mysql+pymysql://root@host.docker.internal:3306/pharmacymanagement

# Allowed frontend origin for CORS
CORS_ORIGIN=http://localhost:3000
